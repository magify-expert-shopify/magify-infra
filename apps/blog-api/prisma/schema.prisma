}

model Page {
  id                                         String                             @id(map: "idx_16523_sqlite_autoindex_page_1")
  url                                        String?                            @unique(map: "idx_16523_page_url_key")
  slug                                       String?
  title                                      String?
  status                                     String?                            @default("DRAFT")
  pageType                                   String?                            @default("OTHER") @map("pagetype")
  seoRole                                    String? @map("seorole")
  searchIntent                               String? @map("searchintent")
  projectId                                  String? @map("projectid")
  seoClusterId                                  String? @map("clusterid")
  trashedAt                                  DateTime?                          @db.Timestamptz(6) @map("trashedat")
  createdAt                                  DateTime?                          @default(now()) @db.Timestamptz(6) @map("createdat")
  updatedAt                                  DateTime?                          @db.Timestamptz(6) @map("updatedat")
  blogArticle                                BlogArticle?
  internalLinkInternalLinkFromPageIdToPage InternalLink[]                     @relation("internallink_frompageidTopage")
  internalLinkInternalLinkToPageIdToPage   InternalLink[]                     @relation("internallink_topageidTopage")
  keywords                                    Keyword[]
  keywordSiteVisibilityObservations           KeywordSiteVisibilityObservation[]
  seoCluster                                 SeoCluster?                        @relation(fields: [seoClusterId], references: [id], onDelete: Cascade)
  project                                    Project?                           @relation(fields: [projectId], references: [id])
  pagePlan                                   PagePlan?

  @@index([projectId], map: "idx_16523_page_projectid_idx")

  @@map("page")
}

model PagePlan {
  id                  String        @id(map: "idx_16565_sqlite_autoindex_pageplan_1")
  keywordGroupId      String?       @unique(map: "idx_16565_pageplan_keywordgroupid_key") @map("keywordgroupid")
  pageId              String?       @unique(map: "idx_16565_pageplan_pageid_key") @map("pageid")
  projectId           String? @map("projectid")
  pageType            String? @map("pagetype")
  subjectExact        String? @map("subjectexact")
  primaryKeyword      String? @map("primarykeyword")
  secondaryKeywords   String? @map("secondarykeywords")
  target              String? @map("target")
  conversionObjective String? @map("conversionobjective")
  approxLength        String? @map("approxlength")
  plan                String? @map("plan")
  createdAt           DateTime?     @default(now()) @db.Timestamptz(6) @map("createdat")
  updatedAt           DateTime?     @db.Timestamptz(6) @map("updatedat")
  keywordGroup        KeywordGroup? @relation(fields: [keywordGroupId], references: [id], onDelete: Cascade)
  page                Page?         @relation(fields: [pageId], references: [id])
  project             Project?      @relation(fields: [projectId], references: [id])

  @@index([pageId], map: "idx_16565_pageplan_pageid_idx")
  @@index([projectId], map: "idx_16565_pageplan_projectid_idx")

  @@map("pageplan")
}

model Project {
  id                               String                             @id(map: "idx_16531_sqlite_autoindex_project_1")
  name                             String?
  slug                             String?                            @unique(map: "idx_16531_project_slug_key")
  description                      String?
  createdAt                        DateTime?                          @default(now()) @db.Timestamptz(6) @map("createdat")
  updatedAt                        DateTime?                          @db.Timestamptz(6) @map("updatedat")
