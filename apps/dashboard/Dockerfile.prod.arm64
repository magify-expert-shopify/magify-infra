FROM node:22-alpine AS builder

WORKDIR /app
RUN corepack enable

ARG NUXT_PUBLIC_DASHBOARD_BLOG_URL
ARG NUXT_PUBLIC_DASHBOARD_PROSPECTION_URL
ARG NUXT_PUBLIC_DASHBOARD_SOCIAL_URL
ARG NUXT_PUBLIC_DASHBOARD_PROXY_MANAGER_URL
ARG NUXT_PUBLIC_DASHBOARD_BLOG_API_URL
ARG NUXT_PUBLIC_DASHBOARD_PROSPECTION_API_URL
ARG NUXT_PUBLIC_DASHBOARD_SOCIAL_API_URL

ENV NUXT_PUBLIC_DASHBOARD_BLOG_URL=$NUXT_PUBLIC_DASHBOARD_BLOG_URL
ENV NUXT_PUBLIC_DASHBOARD_PROSPECTION_URL=$NUXT_PUBLIC_DASHBOARD_PROSPECTION_URL
ENV NUXT_PUBLIC_DASHBOARD_SOCIAL_URL=$NUXT_PUBLIC_DASHBOARD_SOCIAL_URL
ENV NUXT_PUBLIC_DASHBOARD_PROXY_MANAGER_URL=$NUXT_PUBLIC_DASHBOARD_PROXY_MANAGER_URL
ENV NUXT_PUBLIC_DASHBOARD_BLOG_API_URL=$NUXT_PUBLIC_DASHBOARD_BLOG_API_URL
ENV NUXT_PUBLIC_DASHBOARD_PROSPECTION_API_URL=$NUXT_PUBLIC_DASHBOARD_PROSPECTION_API_URL
ENV NUXT_PUBLIC_DASHBOARD_SOCIAL_API_URL=$NUXT_PUBLIC_DASHBOARD_SOCIAL_API_URL

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/blog-api/package.json ./apps/blog-api/package.json
COPY apps/blog-web/package.json ./apps/blog-web/package.json
COPY apps/dashboard/package.json ./apps/dashboard/package.json
COPY apps/prospection-api/package.json ./apps/prospection-api/package.json
COPY apps/prospection-web/package.json ./apps/prospection-web/package.json
COPY apps/social-api/package.json ./apps/social-api/package.json
COPY apps/social-web/package.json ./apps/social-web/package.json

RUN pnpm install --frozen-lockfile --filter dashboard...

COPY apps/dashboard ./apps/dashboard
RUN pnpm --filter dashboard generate

FROM nginx:1.27-alpine AS runner

COPY apps/dashboard/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/apps/dashboard/.output/public /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --start-period=3s --retries=3 \
  CMD wget -q --spider http://127.0.0.1/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
