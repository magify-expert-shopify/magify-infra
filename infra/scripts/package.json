    "install-pgadmin": "powershell -NoProfile -ExecutionPolicy Bypass -File ./install-pgadmin.ps1",
    "load-dotenv": "powershell -NoProfile -ExecutionPolicy Bypass -File ./load-dotenv.ps1",
